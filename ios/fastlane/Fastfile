default_platform(:ios)

APPLE_TEAM_ID = '6734NUF6AV'
APP_IDENTIFIER = 'tv.brunstad.app'

platform :ios do
  desc "Write next TestFlight build number (max across all versions + 1) to fastlane/.next_build_number"
  lane :next_build_number do
    api_key = app_store_connect_api_key(
      key_id: ENV['BCCMEDIA_APP_STORE_CONNECT_KEY_ID'],
      issuer_id: ENV['BCCMEDIA_APP_STORE_CONNECT_ISSUER_ID'],
      key_content: ENV['BCCMEDIA_APP_STORE_CONNECT_KEY_CONTENT_BASE64'],
      is_key_content_base64: true,
      in_house: false
    )

    latest = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      team_id: APPLE_TEAM_ID,
      initial_build_number: 0
    )
    next_num = latest.to_i + 1
    UI.message "Previous TestFlight max build: #{latest}. Next: #{next_num}"
    File.write(File.join(__dir__, '.next_build_number'), next_num.to_s)
  end

  desc "Upload to TestFlight — internal + external Beta group"
  lane :testflight do
    api_key = app_store_connect_api_key(
      key_id: ENV['BCCMEDIA_APP_STORE_CONNECT_KEY_ID'],
      issuer_id: ENV['BCCMEDIA_APP_STORE_CONNECT_ISSUER_ID'],
      key_content: ENV['BCCMEDIA_APP_STORE_CONNECT_KEY_CONTENT_BASE64'],
      is_key_content_base64: true,
      in_house: false
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      team_id: APPLE_TEAM_ID,
      ipa: '../build/ios/ipa/bccm.ipa',
      distribute_external: true,
      groups: ['Beta'],
      skip_waiting_for_build_processing: false,
      changelog: 'Automated build from master'
    )
  end
end
