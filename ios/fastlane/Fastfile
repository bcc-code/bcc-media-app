default_platform(:ios)

APPLE_TEAM_ID = '6734NUF6AV'
APP_IDENTIFIER = 'tv.brunstad.app'

platform :ios do
  desc "Write next TestFlight build number (max across all versions + 1) to fastlane/.next_build_number"
  lane :next_build_number do
    api_key = app_store_connect_api_key(
      key_id: ENV['BCCMEDIA_APP_STORE_CONNECT_KEY_ID'],
      issuer_id: ENV['BCCMEDIA_APP_STORE_CONNECT_ISSUER_ID'],
      key_content: ENV['BCCMEDIA_APP_STORE_CONNECT_KEY_CONTENT_BASE64'],
      is_key_content_base64: true,
      in_house: false
    )

    latest = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      team_id: APPLE_TEAM_ID,
      initial_build_number: 0
    )
    next_num = latest.to_i + 1
    UI.message "Previous TestFlight max build: #{latest}. Next: #{next_num}"
    File.write(File.join(__dir__, '.next_build_number'), next_num.to_s)
  end

  desc "Upload to TestFlight — internal + external Beta group"
  lane :testflight do
    api_key = app_store_connect_api_key(
      key_id: ENV['BCCMEDIA_APP_STORE_CONNECT_KEY_ID'],
      issuer_id: ENV['BCCMEDIA_APP_STORE_CONNECT_ISSUER_ID'],
      key_content: ENV['BCCMEDIA_APP_STORE_CONNECT_KEY_CONTENT_BASE64'],
      is_key_content_base64: true,
      in_house: false
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      team_id: APPLE_TEAM_ID,
      ipa: '../build/ios/ipa/bccm.ipa',
      distribute_external: true,
      groups: ['Beta'],
      skip_waiting_for_build_processing: false,
      changelog: 'Automated build from master'
    )
  end

  desc "Promote an existing TestFlight build to the App Store (submit for review, auto-release)"
  lane :promote_to_app_store do
    build_number = ENV['BUILD_NUMBER']
    app_version = ENV['APP_VERSION']
    UI.user_error!('BUILD_NUMBER env var is required') if build_number.nil? || build_number.empty?
    UI.user_error!('APP_VERSION env var is required') if app_version.nil? || app_version.empty?

    api_key = app_store_connect_api_key(
      key_id: ENV['BCCMEDIA_APP_STORE_CONNECT_KEY_ID'],
      issuer_id: ENV['BCCMEDIA_APP_STORE_CONNECT_ISSUER_ID'],
      key_content: ENV['BCCMEDIA_APP_STORE_CONNECT_KEY_CONTENT_BASE64'],
      is_key_content_base64: true,
      in_house: false
    )

    upload_to_app_store(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      team_id: APPLE_TEAM_ID,
      app_version: app_version,
      build_number: build_number,
      release_notes: { 'en-US' => 'Bug fixes and improvements.' },
      submit_for_review: true,
      automatic_release: true,
      force: true,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false
      }
    )
  end
end
